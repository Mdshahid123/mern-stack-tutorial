<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Trips</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      background-color: #f7f7f7;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <div class="bg-white shadow-sm px-8 py-4 flex justify-between items-center">
    <h1 class="text-xl font-semibold">Trips</h1>
    <div class="text-gray-500">Welcome back 👋</div>
  </div>

  <div class="max-w-5xl mx-auto mt-8 px-4">

    <!-- Empty State -->
    <% if (data.length === 0) { %>
      <div class="text-center mt-20 text-gray-500 text-lg">
        No trips booked yet 🏡
      </div>
    <% } else { %>

      <!-- Upcoming Section -->
      <h2 class="text-2xl font-semibold mb-4">Upcoming trips</h2>

      <div class="space-y-6">

        <% data.forEach(booking => { 
            const today = new Date();
            const checkOut = new Date(booking.checkOut);

            if (checkOut >= today && booking.status === "confirmed") {
        %>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition duration-300 flex flex-col md:flex-row overflow-hidden">

          <!-- Image -->
          <img 
            src="<%= booking.property.image %>" 
            class="w-full md:w-64 h-48 object-cover"
          >

          <!-- Content -->
          <div class="p-5 flex flex-col justify-between flex-1">

            <div>
              <h3 class="text-xl font-semibold mb-1">
                <%= booking.property.title %>
              </h3>

              <p class="text-gray-500 text-sm">
                <%= booking.property.location %>
              </p>

              <p class="mt-3 text-sm text-gray-700">
                <%= new Date(booking.checkIn).toDateString() %> 
                – 
                <%= new Date(booking.checkOut).toDateString() %>
              </p>
            </div>

            <div class="flex justify-between items-center mt-4">
              <span class="font-semibold text-lg">
                ₹<%= booking.totalPrice %>
              </span>

              <div class="space-x-2">
                <button class="px-4 py-2 border rounded-lg text-sm hover:bg-gray-100">
                  View
                </button>
                <button class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm hover:bg-red-600">
                  Cancel
                </button>
              </div>
            </div>

          </div>
        </div>

        <% } }) %>
      </div>

      <!-- Past Section -->
      <h2 class="text-2xl font-semibold mt-10 mb-4">Past trips</h2>

      <div class="space-y-6">

        <% data.forEach(booking => { 
            const today = new Date();
            const checkOut = new Date(booking.checkOut);

            if (checkOut < today || booking.status === "cancelled") {
        %>

        <div class="bg-white rounded-2xl shadow-sm flex flex-col md:flex-row overflow-hidden opacity-80">

          <img 
            src="<%= booking.property.image %>" 
            class="w-full md:w-64 h-48 object-cover"
          >

          <div class="p-5 flex flex-col justify-between flex-1">

            <div>
              <h3 class="text-lg font-semibold">
                <%= booking.property.title %>
              </h3>

              <p class="text-gray-500 text-sm">
                <%= booking.property.location %>
              </p>

              <p class="mt-2 text-sm">
                <%= new Date(booking.checkIn).toDateString() %> 
                – 
                <%= new Date(booking.checkOut).toDateString() %>
              </p>
            </div>

            <div class="flex justify-between items-center mt-4">
              <span class="font-medium">
                ₹<%= booking.totalPrice %>
              </span>

              <span class="text-sm capitalize px-3 py-1 rounded-full 
                <%= booking.status === 'cancelled' ? 'bg-red-100 text-red-600' : 'bg-gray-200 text-gray-700' %>">
                <%= booking.status %>
              </span>
            </div>

          </div>
        </div>

        <% } }) %>
      </div>

    <% } %>

  </div>

</body>
</html>